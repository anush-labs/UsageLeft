{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UsageLeft",
  "version": "0.6.25",
  "identifier": "com.sunstory.usageleft",
  "build": {
    "beforeDevCommand": "npm run bundle:plugins && npm run dev",
    "devUrl": "http://localhost:5253",
    "beforeBuildCommand": "npm run bundle:plugins && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "UsageLeft",
        "width": 1280,
        "height": 700,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": [
      "resources/bundled_plugins/**/*",
      "icons/tray-icon.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU2Njk4QTU0MDMzMEY5MTkKUldRWitUQURWSXBwVnFTY1FBWitxNlpaQnB5S3RVWW1qWHJ3NlRuZ2p3c2hPVzNTa3BUR0V0SXkK",
      "endpoints": [
        "https://github.com/anush-data-portfolio/UsageLeft/releases/latest/download/latest.json"
      ]
    }
  }
}
